Options -Indexes

# ============================================================
# Clean URL Routing for Real Estate World Static Site
# ============================================================

RewriteEngine On

# Force HTTPS (uncomment when deployed to a live server)
# RewriteCond %{HTTPS} off
# RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# --- /blog → blog list page ---
RewriteRule ^blog/?$ /pages/blog-list.html [L]

# --- /blog/[slug] → blog post page ---
RewriteRule ^blog/([a-z0-9-]+)/?$ /pages/blog-post.html?slug=$1 [L,QSA]

# --- Static pages ---
RewriteRule ^about/?$ /pages/about.html [L]
RewriteRule ^contact/?$ /pages/contact.html [L]
RewriteRule ^privacy-policy/?$ /pages/privacy-policy.html [L]
RewriteRule ^disclaimer/?$ /pages/disclaimer.html [L]

# --- Root → blog list ---
RewriteRule ^$ /pages/blog-list.html [L]

# --- Error pages ---
ErrorDocument 404 /pages/blog-list.html

# ============================================================
# Security Headers
# ============================================================
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# ============================================================
# Caching
# ============================================================
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType image/svg+xml "access plus 1 month"
  ExpiresByType image/jpeg "access plus 1 month"
  ExpiresByType image/png "access plus 1 month"
  ExpiresByType image/webp "access plus 1 month"
  ExpiresByType application/json "access plus 1 hour"
  ExpiresByType text/html "access plus 1 hour"
</IfModule>

# Compress text responses
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json text/plain
</IfModule>
